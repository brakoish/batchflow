generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  WORKER
  SUPERVISOR
  OWNER
}

enum BatchStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum StepStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum StepType {
  CHECK
  COUNT
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Organization relation
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  role           Role          @default(OWNER)

  // Worker-specific (for PIN login)
  workerPin      String?   @unique
  workerId       String?   @unique
  worker         Worker?   @relation(fields: [workerId], references: [id])

  @@index([organizationId])
  @@index([workerId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  timezone    String   @default("America/New_York")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  workers     Worker[]
  batches     Batch[]
  recipes     Recipe[]

  @@index([slug])
}

model Worker {
  id             String        @id @default(cuid())
  name           String
  pin            String        @unique
  role           Role
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  progressLogs   ProgressLog[]
  assignments    BatchAssignment[]
  shifts         Shift[]
  logAudits      LogAudit[]
  batchMessages  BatchMessage[]
  pushSubscriptions PushSubscription[]
  user           User?

  @@index([organizationId])
}

model Recipe {
  id             String        @id @default(cuid())
  name           String
  description    String?
  baseUnit       String        @default("units")
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  steps          RecipeStep[]
  batches        Batch[]
  units          RecipeUnit[]

  @@index([organizationId])
}

model RecipeUnit {
  id          String        @id @default(cuid())
  recipeId    String
  recipe      Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name        String
  ratio       Int           @default(1)
  order       Int           @default(0)
  steps       RecipeStep[]

  @@index([recipeId])
}

model RecipeStep {
  id          String        @id @default(cuid())
  recipeId    String
  recipe      Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name        String
  order       Int
  notes       String?
  type        StepType      @default(COUNT)
  unitId      String?
  unit        RecipeUnit?   @relation(fields: [unitId], references: [id])
  batchSteps  BatchStep[]
  materials   StepMaterial[]

  @@index([recipeId])
  @@index([unitId])
}

model StepMaterial {
  id              String      @id @default(cuid())
  recipeStepId    String
  recipeStep      RecipeStep  @relation(fields: [recipeStepId], references: [id], onDelete: Cascade)
  name            String
  quantityPerUnit Float
  unit            String      @default("units")
  createdAt       DateTime    @default(now())

  @@index([recipeStepId])
}

model Batch {
  id              String        @id @default(cuid())
  recipeId        String
  recipe          Recipe        @relation(fields: [recipeId], references: [id])
  name            String
  targetQuantity  Int?
  baseUnit        String        @default("units")
  status          BatchStatus   @default(ACTIVE)
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  startDate       DateTime      @default(now())
  dueDate         DateTime?
  completedDate   DateTime?
  createdAt       DateTime      @default(now())

  // METRC prep fields
  metrcBatchId    String?
  lotNumber       String?
  strain          String?
  packageTag      String?
  steps           BatchStep[]
  assignments     BatchAssignment[]
  messages        BatchMessage[]

  @@index([recipeId])
  @@index([status])
  @@index([organizationId])
}

model BatchAssignment {
  id        String   @id @default(cuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([batchId, workerId])
  @@index([batchId])
  @@index([workerId])
}

enum ShiftStatus {
  ACTIVE
  COMPLETED
}

model Shift {
  id          String      @id @default(cuid())
  workerId    String
  worker      Worker      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  status      ShiftStatus @default(ACTIVE)
  startedAt   DateTime    @default(now())
  endedAt     DateTime?
  notes       String?
  createdAt   DateTime    @default(now())

  @@index([workerId])
  @@index([status])
  @@index([startedAt])
}

model BatchStep {
  id                String        @id @default(cuid())
  batchId           String
  batch             Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  recipeStepId      String
  recipeStep        RecipeStep    @relation(fields: [recipeStepId], references: [id])
  name              String
  order             Int
  type              StepType      @default(COUNT)
  unitLabel         String        @default("units")
  unitRatio         Int           @default(1)
  targetQuantity    Int?
  completedQuantity Int           @default(0)
  status            StepStatus    @default(LOCKED)
  progressLogs      ProgressLog[]
  logAudits         LogAudit[]

  @@index([batchId])
  @@index([recipeStepId])
}

model ProgressLog {
  id          String      @id @default(cuid())
  batchStepId String
  batchStep   BatchStep   @relation(fields: [batchStepId], references: [id], onDelete: Cascade)
  workerId    String
  worker      Worker      @relation(fields: [workerId], references: [id])
  quantity    Int
  note        String?
  createdAt   DateTime    @default(now())
  editedAt    DateTime?

  @@index([batchStepId])
  @@index([workerId])
  @@index([createdAt])
}

model LogAudit {
  id            String    @id @default(cuid())
  progressLogId String?
  batchStepId   String
  batchStep     BatchStep @relation(fields: [batchStepId], references: [id], onDelete: Cascade)
  workerId      String
  worker        Worker    @relation(fields: [workerId], references: [id])
  action        String
  oldQuantity   Int?
  newQuantity   Int?
  oldNote       String?
  newNote       String?
  createdAt     DateTime  @default(now())

  @@index([batchStepId])
  @@index([workerId])
  @@index([createdAt])
}

model BatchMessage {
  id        String   @id @default(cuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@index([batchId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([workerId])
}
